/* ===== Nearby Page ===== */
.page-container {
  height: 100vh;
  background: var(--bg-page);
  box-sizing: border-box;
  overflow: hidden;
}

/* State Centers */
.state-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 0 80rpx;
  text-align: center;
}

.state-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.state-emoji {
  font-size: 56rpx;
}

.state-title {
  font-family: Georgia, 'Noto Serif SC', 'STSong', serif;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.state-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  line-height: 1.6;
}

.state-btn {
  margin-top: 40rpx;
  padding: 20rpx 64rpx;
  background: var(--text-primary);
  color: var(--text-inverse);
  border-radius: 100rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* Loading Spinner */
.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* Main Content Layout */
.nearby-content {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Map Section */
.map-section {
  position: relative;
  flex-shrink: 0;
}

.nearby-map {
  width: 100%;
  height: 500rpx;
}

/* Radius Bar - overlay on map */
.radius-bar {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.radius-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border);
  border-radius: 100rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: var(--text-primary);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.radius-btn .arrow-down {
  font-size: 18rpx;
  color: var(--text-tertiary);
}

.result-count {
  font-size: 22rpx;
  color: var(--text-inverse);
  background: rgba(43, 36, 32, 0.7);
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  backdrop-filter: blur(8px);
}

/* Restaurant List */
.nearby-list {
  flex: 1;
  height: calc(100vh - 500rpx);
  padding: 16rpx 32rpx;
  box-sizing: border-box;
}

/* Nearby Card - horizontal layout */
.nearby-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.nearby-card:active {
  transform: scale(0.985);
}

.nearby-card.highlighted {
  border-left: 6rpx solid var(--accent);
  background: var(--accent-light);
}

/* Card Image */
.nearby-card-img {
  flex-shrink: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: var(--bg-muted);
}

.nearby-card-img image {
  width: 100%;
  height: 100%;
}

.nearby-card-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--accent), var(--accent-hover));
  font-size: 56rpx;
}

/* Card Info */
.nearby-card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.nearby-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.nearby-card-name {
  font-family: Georgia, 'Noto Serif SC', 'STSong', serif;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.nearby-card-distance {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--accent);
  background: var(--accent-light);
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
}

/* Rating */
.nearby-card-rating {
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.star {
  font-size: 22rpx;
}

.star-filled {
  color: var(--gold);
}

.star-empty {
  color: var(--border);
}

.rating-count {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-left: 6rpx;
}

/* Meta */
.nearby-card-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-badge {
  font-size: 20rpx;
  color: var(--accent);
  background: var(--accent-light);
  padding: 2rpx 12rpx;
  border-radius: 100rpx;
}

.meta-price {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* Tags */
.nearby-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 4rpx;
}

.mini-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  line-height: 1;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
}

.mini-tag text {
  font-size: 18rpx;
  line-height: 1;
}
