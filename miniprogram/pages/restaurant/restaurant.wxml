<view class="page-container">
  <!-- Filter Bar -->
  <view class="filter-bar">
    <picker mode="selector" range="{{cityRange}}" bindchange="onCityChange">
      <view class="filter-select">
        <text>{{cityFilter || '全部城市'}}</text>
        <text class="arrow-down">▼</text>
      </view>
    </picker>

    <picker mode="selector" range="{{tagRange}}" range-key="name" bindchange="onTagChange">
      <view class="filter-select">
        <text>{{tagFilterName}}</text>
        <text class="arrow-down">▼</text>
      </view>
    </picker>

    <view class="search-input-wrap">
      <input class="search-input" placeholder="搜索餐厅" value="{{searchKeyword}}" bindinput="onSearchInput" />
    </view>

    <view class="result-count">
      <text>共 {{filteredRestaurants.length}} 家餐厅</text>
    </view>

    <view wx:if="{{isAdmin}}" class="manage-tags-btn" bindtap="openTagManage">
      <text>管理标签</text>
    </view>
  </view>

  <!-- Restaurant List -->
  <scroll-view scroll-y class="restaurant-scroll" bindscrolltolower="onScrollToLower" lower-threshold="200">
    <view class="restaurant-list">
      <!-- AI 智能推荐入口卡片 -->
      <view class="ai-hero-card" bindtap="openAiOverlay">
        <text class="ai-hero-label">✦ AI 智能推荐</text>
        <text class="ai-hero-cta">不知道吃什么？</text>
        <text class="ai-hero-sub">描述你的口味，AI 帮你挑选</text>
      </view>
      <block wx:for="{{paginatedRestaurants}}" wx:key="id">
        <view class="restaurant-card">
          <!-- Card Images -->
          <view class="card-images">
            <swiper wx:if="{{item.images.length > 0}}" class="card-swiper"
              indicator-dots="{{item.images.length > 1}}"
              indicator-color="rgba(255,255,255,0.4)"
              indicator-active-color="#ffffff"
              autoplay="{{false}}"
              circular="{{true}}">
              <swiper-item wx:for="{{item.images}}" wx:for-item="img" wx:key="*this">
                <image src="{{img}}" mode="aspectFill" class="card-image-full" catchtap="previewImage" data-url="{{img}}" data-images="{{item.images}}" />
              </swiper-item>
            </swiper>
            <view wx:else class="card-image-placeholder {{item.gradientClass}}">
              <text class="placeholder-emoji">🍜</text>
              <text class="placeholder-icon" style="color: rgba(255,255,255,0.7)">暂无图片</text>
            </view>
            <view wx:if="{{item.images.length > 1}}" class="image-count-badge">
              <text>{{item.images.length}}张</text>
            </view>
          </view>

          <!-- Card Body -->
          <view class="card-body" bindtap="openDetail" data-item="{{item}}">
            <view class="card-header">
              <text class="card-name">{{item.name}}</text>
              <text wx:if="{{item.avgPrice}}" class="card-price">¥{{item.avgPrice}}/人</text>
            </view>

            <view wx:if="{{item.visitCount > 0}}" class="card-rating">
              <block wx:for="{{5}}" wx:for-item="star" wx:key="*this">
                <text class="star {{star < item.avgRating ? 'star-filled' : 'star-empty'}}">★</text>
              </block>
              <text class="rating-text">{{item.avgRating}} ({{item.visitCount}}次)</text>
            </view>

            <text wx:if="{{item.description}}" class="card-desc">{{item.description}}</text>

            <view class="card-meta">
              <text wx:if="{{item.province || item.city}}" class="meta-city">{{item.province ? item.province + ' ' : ''}}{{item.city}}</text>
              <text wx:if="{{item.address}}" class="meta-address">{{item.address}}</text>
            </view>

            <!-- Tags -->
            <view wx:if="{{item.tags && item.tags.length}}" class="card-tags">
              <block wx:for="{{item.tags}}" wx:for-item="tag" wx:key="id">
                <text class="tag-item" style="{{tag.tagStyle}}">{{tag.name}}</text>
              </block>
            </view>

            <!-- Recommended Dishes (expandable) -->
            <view wx:if="{{expandedId === item.id && item.recommendedDishes}}" class="card-dishes">
              <text class="dishes-title">推荐菜品</text>
              <text class="dishes-text">{{item.recommendedDishes}}</text>
            </view>

            <!-- Actions -->
            <view class="card-actions">
              <view class="action-btn" catchtap="toggleDishes" data-id="{{item.id}}">
                <text>{{expandedId === item.id ? '收起' : '推荐菜'}}</text>
              </view>
              <view class="action-btn" catchtap="openCheckIn" data-item="{{item}}">
                <text>打卡</text>
              </view>
              <view wx:if="{{item.canEdit}}" class="action-btn" catchtap="openEdit" data-item="{{item}}">
                <text>编辑</text>
              </view>
              <view class="action-btn" catchtap="openMap" data-item="{{item}}">
                <text>地图</text>
              </view>
              <view wx:if="{{item.canEdit}}" class="action-btn action-btn-danger" catchtap="confirmDelete" data-item="{{item}}">
                <text>删除</text>
              </view>
            </view>
          </view>
        </view>
      </block>

      <!-- Empty State -->
      <view wx:if="{{paginatedRestaurants.length === 0}}" class="empty-state">
        <view class="empty-icon-wrap">
          <text class="empty-emoji">🔍</text>
        </view>
        <text class="empty-title">没有找到餐厅</text>
        <text class="empty-desc">试试调整筛选条件或添加新餐厅</text>
      </view>

      <!-- Load More -->
      <view wx:if="{{paginatedRestaurants.length < filteredRestaurants.length}}" class="load-more">
        <text>上拉加载更多</text>
      </view>
    </view>
  </scroll-view>

</view>

<!-- Edit Popup -->
<view wx:if="{{editVisible}}" class="form-fullscreen">
  <view class="form-fs-head">
    <text class="form-fs-title">编辑餐厅</text>
    <view class="form-fs-close" bindtap="closeEdit">
      <text>✕</text>
    </view>
  </view>
  <view class="form-fs-scroll-wrap">
    <scroll-view scroll-y class="form-fs-body">
      <view class="form-group">
        <text class="form-label">餐厅名称 *</text>
        <input class="form-input" value="{{editForm.name}}" data-field="name" bindinput="onEditInput" placeholder="请输入餐厅名称" />
      </view>
      <view class="form-group">
        <text class="form-label">省份/城市(选址后自动填充)</text>
        <picker mode="region" bindchange="onEditRegionChange" value="{{editRegion}}">
          <view class="region-picker-display">
            <text class="{{editRegionDisplay ? '' : 'placeholder'}}">{{editRegionDisplay || '请选择省份和城市'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="form-group">
        <text class="form-label">地址(选址后自动填充)</text>
        <view class="location-input-row">
          <input class="form-input location-input" value="{{editForm.address}}" data-field="address" bindinput="onEditInput" placeholder="请输入或选择地址" />
          <view class="location-btn" bindtap="chooseEditLocation">
            <text>📍 选择位置</text>
          </view>
        </view>
        <view wx:if="{{editForm.latitude}}" class="coord-display">
          <text class="coord-badge">{{editForm.latitude.toFixed(4)}}, {{editForm.longitude.toFixed(4)}}</text>
        </view>
        <map
          wx:if="{{editForm.latitude}}"
          class="edit-map-preview"
          latitude="{{editForm.latitude}}"
          longitude="{{editForm.longitude}}"
          markers="{{editMarkers}}"
          scale="16"
          show-location
          enable-zoom
          enable-scroll
        />
      </view>
      <view class="form-group">
        <text class="form-label">人均价格</text>
        <input class="form-input" type="digit" value="{{editForm.avgPrice}}" data-field="avgPrice" bindinput="onEditInput" placeholder="请输入人均价格" />
      </view>
      <view class="form-group">
        <text class="form-label">描述</text>
        <textarea class="form-textarea" value="{{editForm.description}}" data-field="description" bindinput="onEditInput" placeholder="请输入描述" />
      </view>
      <view class="form-group">
        <text class="form-label">推荐菜品</text>
        <textarea class="form-textarea" value="{{editForm.recommendedDishes}}" data-field="recommendedDishes" bindinput="onEditInput" placeholder="请输入推荐菜品" />
      </view>
      <view class="form-group">
        <text class="form-label">标签</text>
        <view class="tag-checkboxes">
          <block wx:for="{{allTags}}" wx:key="id">
            <view class="tag-checkbox {{editTagMap[item.id] ? 'checked' : ''}}" bindtap="onEditTagToggle" data-id="{{item.id}}">
              <text class="checkbox-dot" style="background: {{editTagMap[item.id] ? (item.color || '#CC8048') : '#E0DAD2'}}"></text>
              <text>{{item.name}}</text>
            </view>
          </block>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">图片（最多3张）</text>
        <view class="image-grid">
          <view wx:for="{{editImageItems}}" wx:key="id" class="image-grid-item">
            <image src="{{item.displayUrl}}" mode="aspectFill" />
            <view class="image-grid-remove" bindtap="removeEditImage" data-id="{{item.id}}">×</view>
          </view>
          <view wx:if="{{editImageItems.length < 3}}" class="image-grid-item image-grid-add" bindtap="chooseEditImage">
            <text class="upload-icon">+</text>
            <text class="upload-text">添加</text>
          </view>
        </view>
      </view>
      <view style="height: 40rpx;"></view>
      <view class="btn btn-cancel" bindtap="closeEdit"><text>取消</text></view>
    <view class="btn btn-primary" bindtap="handleEditSubmit"><text>保存</text></view>
    </scroll-view>
  </view>

</view>

<!-- Check-in Popup -->
<view wx:if="{{checkInVisible}}" class="form-fullscreen">
  <view class="form-fs-head">
    <text class="form-fs-title">打卡</text>
    <view class="form-fs-close" bindtap="closeCheckIn">
      <text>✕</text>
    </view>
  </view>
  <view class="form-fs-scroll-wrap">
    <scroll-view scroll-y class="form-fs-body">
      <view class="form-group">
        <text class="form-label">评分</text>
        <view class="star-rating">
          <block wx:for="{{5}}" wx:for-item="star" wx:key="*this">
            <text class="star-btn {{star < checkInForm.rating ? 'star-filled' : ''}}" bindtap="onCheckInRating" data-rating="{{star + 1}}">★</text>
          </block>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">消费金额</text>
        <input class="form-input" type="digit" value="{{checkInForm.cost}}" data-field="cost" bindinput="onCheckInInput" placeholder="请输入消费金额" />
      </view>
      <view class="form-group">
        <text class="form-label">到访日期</text>
        <picker mode="date" value="{{checkInForm.visitDate}}" bindchange="onCheckInDateChange">
          <view class="form-input picker-value">
            <text>{{checkInForm.visitDate || '请选择日期'}}</text>
          </view>
        </picker>
      </view>
      <view class="form-group">
        <text class="form-label">评论</text>
        <textarea class="form-textarea" value="{{checkInForm.comment}}" data-field="comment" bindinput="onCheckInInput" placeholder="分享你的体验" />
      </view>
      <view style="height: 40rpx;"></view>
     
        <view class="btn btn-cancel" bindtap="closeCheckIn"><text>取消</text></view>
    <view class="btn btn-primary" bindtap="handleCheckIn"><text>打卡</text></view>


    </scroll-view>
  </view>

</view>

<!-- Map Popup -->
<view wx:if="{{mapVisible}}" class="popup-overlay" catchtouchmove="preventTouchMove" bindtap="closeMap">
  <view class="popup-content popup-map" catchtouchmove="preventTouchMove" catchtap="stopPropagation">
    <view class="popup-header">
      <text class="popup-title">{{mapRestaurant.name}} - 地图</text>
      <text class="popup-close" bindtap="closeMap">×</text>
    </view>
    <view class="popup-body">
      <view class="map-info-bar">
        <text class="map-address">{{mapRestaurant.address}}</text>
        <view class="map-nav-btn" bindtap="navigateToRestaurant">导航</view>
      </view>
      <map
        class="map-view"
        latitude="{{mapLatitude}}"
        longitude="{{mapLongitude}}"
        scale="14"
        show-location
        markers="{{[{id: 1, latitude: mapLatitude, longitude: mapLongitude, title: mapRestaurant.name}]}}"
      />
    </view>
  </view>
</view>

<!-- Tag Management Popup -->
<view wx:if="{{tagManageVisible}}" class="popup-overlay" catchtouchmove="preventTouchMove" bindtap="closeTagManage">
  <view class="popup-content" catchtouchmove="preventTouchMove" catchtap="stopPropagation">
    <view class="popup-header">
      <text class="popup-title">管理标签</text>
      <text class="popup-close" bindtap="closeTagManage">×</text>
    </view>
    <scroll-view scroll-y class="popup-body">
      <view class="tag-add-row">
        <input class="form-input tag-name-input" value="{{newTagName}}" bindinput="onNewTagNameInput" placeholder="新标签名称" />
        <view class="color-preview" style="background: {{newTagColor}}" bindtap="toggleColorPicker"></view>
        <view class="btn btn-primary btn-sm" bindtap="handleAddTag">
          <text>添加</text>
        </view>
      </view>
      <!-- Inline Color Picker -->
      <view wx:if="{{colorPickerVisible}}" class="color-picker-inline">
        <view class="color-picker-sv-pad" style="background: {{hueColor}}" catchtouchmove="onSVPadMove" catchtouchstart="onSVPadStart">
          <view class="sv-pad-white"></view>
          <view class="sv-pad-black"></view>
          <view class="sv-picker" style="left: {{svLeft}}; top: {{svTop}}"></view>
        </view>
        <view class="color-picker-hue-wrap">
          <view class="hue-bar" catchtouchmove="onHueMove" catchtouchstart="onHueStart">
            <view class="hue-thumb" style="left: {{hueLeft}}"></view>
          </view>
        </view>
        <view class="color-picker-hex-row">
          <text class="hex-label">#</text>
          <input class="hex-input" value="{{hexInput}}" bindinput="onHexInput" maxlength="6" />
          <view class="color-picker-ok-btn" bindtap="confirmColorPick">
            <text>确定</text>
          </view>
        </view>
      </view>
      <view class="color-presets">
        <view
          class="color-preset {{newTagColor === color ? 'active' : ''}}"
          wx:for="{{presetColors}}"
          wx:for-item="color"
          wx:key="*this"
          style="background: {{color}}"
          bindtap="onSelectColor"
          data-color="{{color}}"
        ></view>
      </view>
      <view class="tag-list">
        <block wx:for="{{allTags}}" wx:key="id">
          <view class="tag-list-item">
            <view class="tag-color-dot" style="background: {{item.color || '#CC8048'}}"></view>
            <text class="tag-list-name">{{item.name}}</text>
            <view class="tag-delete-btn" bindtap="handleDeleteTag" data-tag="{{item}}">
              <text>×</text>
            </view>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>
</view>

<!-- Detail Overlay -->
<view class="detail-overlay {{detailVisible ? 'show' : ''}}">
  <view class="detail-close">
    <view class="detail-close-btn" bindtap="closeDetail">✕</view>
    <text wx:if="{{detailData.visitCount > 0}}" class="detail-visit-count">已打卡 {{detailData.visitCount}} 次</text>
  </view>

  <!-- Hero -->
  <view class="detail-hero">
    <image wx:if="{{detailData.heroImage}}" src="{{detailData.heroImage}}" mode="aspectFill" class="detail-hero-image" />
    <view wx:else class="detail-hero-placeholder {{detailData.gradientClass}}">
      <text style="font-size: 120rpx;">🍜</text>
    </view>
  </view>

  <!-- Content -->
  <view class="detail-content">
    <view class="detail-name">{{detailData.name}}</view>

    <view class="detail-cuisine">
      <text>{{detailData.tags[0].name || '美食'}}</text>
      <text wx:if="{{detailData.province || detailData.city}}"> · {{detailData.province ? detailData.province + ' ' : ''}}{{detailData.city}}</text>
    </view>

    <view class="detail-stats">
      <view class="detail-stat">
        <text class="val">{{detailData.avgRating || '-'}}</text>
        <text class="lbl">评分</text>
      </view>
      <view class="detail-stat">
        <text class="val">{{detailData.avgPrice ? '¥' + detailData.avgPrice : '-'}}</text>
        <text class="lbl">人均</text>
      </view>
      <view class="detail-stat">
        <text class="val">{{detailData.visitCount || 0}}</text>
        <text class="lbl">打卡</text>
      </view>
    </view>

    <!-- Recommended Dishes -->
    <view wx:if="{{detailData.recommendedDishes}}" class="detail-section">
      <view class="detail-section-title">推荐菜</view>
      <view class="dish-pills">
        <block wx:for="{{detailData.dishList}}" wx:key="*this">
          <view class="dish-pill">{{item}}</view>
        </block>
      </view>
    </view>

    <!-- Address -->
    <view wx:if="{{detailData.address}}" class="detail-section">
      <view class="detail-section-title">地址</view>
      <view class="detail-address">{{detailData.address}}</view>
    </view>

    <!-- Description -->
    <view wx:if="{{detailData.description}}" class="detail-section">
      <view class="detail-section-title">描述</view>
      <view class="detail-note">{{detailData.description}}</view>
    </view>

    <!-- Visit History -->
    <view wx:if="{{detailVisits.length > 0}}" class="detail-section">
      <view class="detail-section-title">打卡记录</view>
      <block wx:for="{{detailVisits}}" wx:key="id">
        <view class="visit-item">
          <view class="visit-header">
            <text class="visit-rating">{{item.rating}} ★</text>
            <text class="visit-date">{{item.visitDate}}</text>
            <text wx:if="{{item.cost}}" class="visit-cost">¥{{item.cost}}</text>
          </view>
          <view wx:if="{{item.comment}}" class="visit-comment">{{item.comment}}</view>
        </view>
      </block>
    </view>
  </view>
</view>

<!-- AI 对话弹窗 -->
<view class="ai-dialog {{aiOverlayVisible ? 'show' : ''}}" catchtouchmove="preventTouchMove">
  <view class="ai-dialog-mask" bindtap="closeAiOverlay"></view>
  <view class="ai-dialog-sheet" catchtap="stopPropagation" style="bottom:{{aiKbHeight}}px">
    <view class="ai-dialog-head">
      <text class="ai-dialog-title">AI 智能推荐</text>
      <view class="ai-dialog-close" bindtap="closeAiOverlay"><text>✕</text></view>
    </view>
    <scroll-view scroll-y class="ai-dialog-scroll">
      <view class="ai-dialog-welcome" wx:if="{{aiRecMessages.length === 0 && !aiRecLoading}}">
        <text class="ai-wel-icon">✦</text>
        <text class="ai-wel-title">告诉我你想吃什么</text>
        <text class="ai-wel-hint">比如："想吃辣的，人均50左右"</text>
      </view>
      <view class="ai-dialog-msgs" wx:if="{{aiRecMessages.length > 0}}">
        <block wx:for="{{aiRecMessages}}" wx:key="index">
          <view class="ai-row {{item.role === 'user' ? 'ai-row-r' : 'ai-row-l'}}">
            <text wx:if="{{item.role === 'user'}}" class="ai-bubble ai-bubble-u">{{item.content}}</text>
            <view wx:else class="ai-bubble-wrap">
              <block wx:if="{{item.recommendations && item.recommendations.length > 0}}">
                <view class="ai-card" wx:for="{{item.recommendations}}" wx:for-item="rec" wx:key="id">
                  <view class="ai-card-bar"></view>
                  <view class="ai-card-body">
                    <view class="ai-card-top">
                      <text class="ai-card-name">{{rec.name}}</text>
                      <text class="ai-card-price" wx:if="{{rec.avgPrice}}">人均 {{rec.avgPrice}}</text>
                    </view>
                    <view class="ai-card-meta">
                      <text class="ai-card-city" wx:if="{{rec.city}}">{{rec.city}}</text>
                      <text wx:if="{{rec.address}}">{{rec.address}}</text>
                    </view>
                    <text class="ai-card-desc" wx:if="{{rec.description}}">{{rec.description}}</text>
                    <view class="ai-card-why" wx:if="{{rec.reason}}"><text>{{rec.reason}}</text></view>
                  </view>
                </view>
              </block>
              <text wx:else class="ai-bubble ai-bubble-a">{{item.content}}</text>
            </view>
          </view>
        </block>
      </view>
      <view class="ai-loading" wx:if="{{aiRecLoading}}">
        <text class="ai-ldot"></text>
        <text class="ai-ldot"></text>
        <text class="ai-ldot"></text>
      </view>
    </scroll-view>
    <view class="ai-dialog-bar">
      <input class="ai-dialog-input" placeholder="描述你想吃什么..." value="{{aiRecInput}}" bindinput="onAiRecInput" bindconfirm="handleAiRecSend" confirm-type="send" adjust-position="{{false}}" bindfocus="onAiKbShow" bindblur="onAiKbHide" />
      <view class="ai-dialog-send {{aiRecInput && !aiRecLoading ? 'on' : ''}}" bindtap="handleAiRecSend">
        <text>{{aiRecLoading ? '...' : '发送'}}</text>
      </view>
    </view>
  </view>
</view>

<!-- 隐形返回拦截器：弹框打开时激活，捕获真机返回手势关闭弹框而非退出小程序 -->
<page-container
  show="{{backGuardActive}}"
  position="center"
  overlay="{{false}}"
  duration="{{0}}"
  bind:leave="onBackGuardLeave"
  custom-style="position:fixed;top:-9999px;left:-9999px;width:0;height:0;overflow:hidden"
/>
