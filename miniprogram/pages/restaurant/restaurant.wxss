.page-container {
  padding: 24rpx 0 140rpx;
  background: var(--bg-page);
  min-height: 100vh;
  box-sizing: border-box;
}

/* Filter Bar */
.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx 40rpx 24rpx;
  align-items: center;
}

.filter-select {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border);
  border-radius: 100rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  transition: all 0.2s;
}

.filter-select:active {
  transform: scale(0.97);
}

.arrow-down {
  font-size: 18rpx;
  color: var(--text-tertiary);
}

.search-input-wrap {
  flex: 1;
  min-width: 200rpx;
}

.search-input {
  background: var(--bg-surface);
  border: 1rpx solid var(--border);
  border-radius: 24rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 72rpx;
}

.result-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.manage-tags-btn {
  background: var(--bg-surface);
  color: var(--text-secondary);
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid var(--border);
  transition: all 0.2s;
}

.manage-tags-btn:active {
  background: var(--bg-muted);
  transform: scale(0.97);
}

/* Restaurant List */
.restaurant-scroll {
  height: calc(100vh - 200rpx);
}

.restaurant-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 40rpx;
}

.restaurant-card {
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border);
  overflow: hidden;
  animation: cardFadeIn 0.35s ease-out both;
  transition: transform 0.15s;
}

.restaurant-card:active {
  transform: scale(0.985);
}

@keyframes cardFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Card Images */
.card-images {
  height: 280rpx;
  overflow: hidden;
  position: relative;
}

.card-swiper {
  width: 100%;
  height: 100%;
}

.card-image-full {
  width: 100%;
  height: 100%;
}

.card-image-placeholder {
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: rgba(255,255,255,0.85);
  background: linear-gradient(135deg, #B09080, #D4B8A0);
}

.card-image-placeholder.img-sichuan,.detail-hero-placeholder.img-sichuan{background:linear-gradient(135deg,#c0392b,#e67e22)}
.card-image-placeholder.img-cantonese,.detail-hero-placeholder.img-cantonese{background:linear-gradient(135deg,#d4a03c,#e8c86a)}
.card-image-placeholder.img-japanese,.detail-hero-placeholder.img-japanese{background:linear-gradient(135deg,#e8a0a0,#f0d0c0)}
.card-image-placeholder.img-hotpot,.detail-hero-placeholder.img-hotpot{background:linear-gradient(135deg,#a02020,#d44020)}
.card-image-placeholder.img-western,.detail-hero-placeholder.img-western{background:linear-gradient(135deg,#6b7b3a,#a09060)}
.card-image-placeholder.img-bbq,.detail-hero-placeholder.img-bbq{background:linear-gradient(135deg,#c07030,#e09050)}
.card-image-placeholder.img-seafood,.detail-hero-placeholder.img-seafood{background:linear-gradient(135deg,#3070a0,#50a0c0)}
.card-image-placeholder.img-dessert,.detail-hero-placeholder.img-dessert{background:linear-gradient(135deg,#d080a0,#f0c0d0)}
.card-image-placeholder.img-noodle,.detail-hero-placeholder.img-noodle{background:linear-gradient(135deg,#c09040,#e0b060)}
.card-image-placeholder.img-korean,.detail-hero-placeholder.img-korean{background:linear-gradient(135deg,#a05030,#d07050)}
.card-image-placeholder.img-se-asian,.detail-hero-placeholder.img-se-asian{background:linear-gradient(135deg,#508040,#80a050)}
.card-image-placeholder.img-shanghainese,.detail-hero-placeholder.img-shanghainese{background:linear-gradient(135deg,#806040,#b09060)}

.image-count-badge {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.placeholder-emoji {
  font-size: 64rpx;
}

.placeholder-icon {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* Card Body */
.card-body {
  padding: 24rpx 28rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.card-name {
  font-family: Georgia, 'Noto Serif SC', 'STSong', serif;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.card-price {
  color: var(--text-secondary);
  font-size: 24rpx;
  font-variant-numeric: tabular-nums;
}

.card-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.star {
  font-size: 24rpx;
}

.star-filled {
  color: var(--accent);
}

.star-empty {
  color: var(--border);
}

.rating-text {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

.card-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.meta-city {
  background: var(--accent-light);
  color: var(--accent);
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-xs);
  font-weight: 500;
}

.meta-address {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* Tags */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.tag-item {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-xs);
  font-weight: 500;
}

/* Dishes */
.card-dishes {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 12rpx;
  line-height: 1.5;
  padding: 16rpx 20rpx;
  background: var(--bg-muted);
  border-radius: var(--radius-sm);
}

.card-dishes .dishes-title {
  font-weight: 600;
  color: var(--text-primary);
  font-size: 24rpx;
}

.card-dishes .dishes-text {
  color: var(--text-primary);
}

/* Actions */
.card-actions {
  display: flex;
  border-top: 1rpx solid var(--border);
  padding-top: 16rpx;
  margin-top: 16rpx;
  justify-content: space-around;
}

.action-btn {
  color: var(--text-secondary);
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
  transition: all 0.2s;
}

.action-btn:active {
  transform: scale(0.97);
}

.action-btn-danger {
  color: var(--danger);
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 20rpx;
}

.empty-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: var(--accent-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.empty-emoji {
  font-size: 80rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.load-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* Popup */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 1000;
  animation: fadeIn 0.2s ease-out;
}

.popup-content {
  background: var(--bg-surface);
  border-radius: 40rpx 40rpx 0 0;
  padding: 32rpx;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.popup-map {
  border-radius: 40rpx 40rpx 0 0;
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border);
}

.popup-title {
  font-family: Georgia, 'Noto Serif SC', 'STSong', serif;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.popup-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 1rpx solid var(--border);
  background: var(--bg-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-primary);
}

.popup-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* Form */
.form-group {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.form-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.form-input {
  background: var(--bg-page);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  min-height: 84rpx;
  line-height: 1.6;
  box-sizing: border-box;
  transition: border-color 0.15s;
}

.form-input:focus {
  border-color: var(--accent);
}

.form-textarea {
  background: var(--bg-page);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  min-height: 120rpx;
  transition: border-color 0.15s;
}

.picker-value {
  display: flex;
  align-items: center;
}

/* Tag Checkboxes */
.tag-checkboxes {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-checkbox {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  border-radius: var(--radius-xs);
  background: var(--bg-surface);
  border: 1rpx solid var(--border);
  font-size: 24rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.tag-checkbox.checked {
  background: var(--accent-light);
  border-color: var(--accent-light);
  color: var(--accent);
}

.checkbox-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

/* Image Grid */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-grid-item {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  position: relative;
}

.image-grid-item image {
  width: 100%;
  height: 100%;
}

.image-grid-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.image-grid-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: var(--bg-muted);
  border: 2rpx dashed var(--border);
}

.image-grid-add .upload-icon {
  font-size: 48rpx;
  color: var(--text-tertiary);
}

.image-grid-add .upload-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* Buttons */
.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 100rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: transform 0.15s;
}

.btn:active {
  transform: scale(0.97);
}

.btn-cancel {
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--border);
}

.btn-primary {
  background: var(--text-primary);
  color: var(--bg-surface);
  border: none;
}

.btn-sm {
  flex: none;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
}

/* Star Rating */
.star-rating {
  display: flex;
  gap: 8rpx;
}

.star-btn {
  font-size: 48rpx;
  color: var(--border);
  padding: 4rpx;
  transition: transform 0.15s;
}

.star-btn:active {
  transform: scale(0.9);
}

.star-btn.star-filled {
  color: var(--accent);
}

/* Map */
.map-address {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  display: block;
}

.map-view {
  width: 100%;
  height: 500rpx;
  border-radius: var(--radius-md);
}

/* Tag Management */
.tag-add-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.tag-name-input {
  flex: 1;
}

.tag-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 24rpx;
}

.tag-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
}

.tag-color-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
}

.tag-list-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.tag-delete-btn {
  font-size: 32rpx;
  color: var(--text-tertiary);
  padding: 8rpx 16rpx;
}

/* Color Picker */
.color-preview {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 1rpx solid var(--border);
  flex-shrink: 0;
  align-self: center;
}

.color-presets {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
  margin-bottom: 24rpx;
}

.color-preset {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.color-preset.active {
  border-color: var(--text-primary);
  transform: scale(1.15);
}

.color-picker-inline {
  background: var(--bg-muted);
  border-radius: var(--radius-sm);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.color-picker-sv-pad {
  width: 100%;
  height: 300rpx;
  border-radius: var(--radius-sm);
  position: relative;
}

.sv-pad-white {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to right, #fff, transparent);
  border-radius: var(--radius-sm);
}

.sv-pad-black {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to top, #000, transparent);
  border-radius: var(--radius-sm);
}

.sv-picker {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 0 4rpx rgba(0, 0, 0, 0.3);
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.color-picker-hue-wrap {
  margin-top: 20rpx;
  padding: 0 8rpx;
}

.hue-bar {
  width: 100%;
  height: 24rpx;
  border-radius: 12rpx;
  background: linear-gradient(to right,
    #ff0000, #ffff00, #00ff00, #00ffff, #0000ff, #ff00ff, #ff0000
  );
  position: relative;
}

.hue-thumb {
  position: absolute;
  top: -8rpx;
  width: 12rpx;
  height: 40rpx;
  background: #fff;
  border-radius: 6rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.2);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transform: translateX(-50%);
  pointer-events: none;
}

.color-picker-hex-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
}

.hex-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.hex-input {
  flex: 1;
  background: var(--bg-surface);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  font-family: monospace;
  min-height: 64rpx;
}

.color-picker-ok-btn {
  background: var(--text-primary);
  color: #fff;
  padding: 12rpx 28rpx;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
}

/* ===== DETAIL OVERLAY ===== */
/* 1px = 2rpx, matching index.html exactly */

.detail-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--bg-page);
  z-index: 2000;
  display: none;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

.detail-overlay.show {
  display: flex;
  animation: detailIn .35s ease-out;
}

@keyframes detailIn {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* close bar: padding 14px 20px → 28rpx 40rpx */
.detail-close {
  flex-shrink: 0;
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 28rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--bg-page);
}

/* button: 36px round → 72rpx */
.detail-close-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 1rpx solid var(--border);
  background: var(--bg-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--text-primary);
  transition: background 0.2s;
}

.detail-close-btn:active {
  background: var(--border);
}

/* visit-date: 12px → 24rpx */
.detail-visit-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* hero: 240px → 480rpx */
.detail-hero {
  flex-shrink: 0;
  height: 480rpx;
  position: relative;
  overflow: hidden;
}

.detail-hero-image {
  width: 100%;
  height: 100%;
}

.detail-hero-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.85);
}

/* content: padding 24px 20px 40px → 48rpx 40rpx 80rpx */
.detail-content {
  flex: 1;
  padding: 48rpx 40rpx 80rpx;
  box-sizing: border-box;
  overflow: hidden;
}

/* name: 28px bold, margin-bottom 4px → 8rpx */
.detail-name {
  font-family: Georgia, 'Noto Serif SC', 'STSong', serif;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

/* cuisine: padding 4px 12px, font 12px, radius 8px, margin-bottom 16px */
.detail-cuisine {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: 16rpx;
  background: var(--accent-light);
  color: var(--accent);
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 32rpx;
  width: auto;
  max-width: fit-content;
}

/* stats: gap 24px, margin-bottom 24px */
.detail-stats {
  display: flex;
  gap: 48rpx;
  margin-bottom: 48rpx;
}

.detail-stat {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* val: 20px bold */
.detail-stat .val {
  font-size: 40rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  color: var(--accent);
}

/* lbl: 11px */
.detail-stat .lbl {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* section: margin-bottom 20px → 40rpx */
.detail-section {
  margin-bottom: 40rpx;
}

/* section h3: font 13px, margin-bottom 8px */
.detail-section-title {
  font-size: 26rpx;
  color: var(--text-tertiary);
  font-weight: 500;
  margin-bottom: 16rpx;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* dish pills: gap 6px, pill padding 8px 16px, radius 10px, font 13px */
.dish-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.dish-pill {
  padding: 16rpx 32rpx;
  border-radius: 20rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border);
  font-size: 26rpx;
  color: var(--text-primary);
}

/* address: p tag, font 15px, line-height 1.7 */
.detail-address {
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--text-primary);
}

/* note: padding 16px, font 14px, line-height 1.7 */
.detail-note {
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border);
  padding: 32rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-primary);
  font-style: italic;
  box-sizing: border-box;
  word-break: break-word;
}

/* Detail Visit History */
.visit-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.visit-item:last-child {
  border-bottom: none;
}

.visit-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.visit-rating {
  color: var(--accent);
  font-size: 26rpx;
  font-weight: 600;
}

.visit-date {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.visit-cost {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.visit-comment {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-top: 6rpx;
}
