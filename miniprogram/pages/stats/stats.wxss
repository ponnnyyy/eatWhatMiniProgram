.stats-page {
  padding: 24rpx 40rpx 140rpx;
  box-sizing: border-box;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 24rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* Overview Cards */
.overview-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  background: var(--bg-surface);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-sizing: border-box;
  overflow: hidden;
  animation: fadeInUp 0.35s ease-out both;
}

.stat-card:nth-child(2) { animation-delay: 0.05s; }
.stat-card:nth-child(3) { animation-delay: 0.1s; }
.stat-card:nth-child(4) { animation-delay: 0.15s; }

.stat-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.stat-value-text {
  font-size: 32rpx;
}

.stat-sub {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

/* Chart Cards */
.chart-card {
  background: var(--bg-surface);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
  overflow: hidden;
  animation: fadeInUp 0.35s ease-out 0.2s both;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.chart-badge {
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-xs);
  background: var(--accent-light);
  color: var(--accent);
}

/* Bar Chart */
.bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.bar-label {
  width: 100rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: right;
  flex-shrink: 0;
}

.bar-track {
  flex: 1;
  height: 28rpx;
  background: var(--bg-muted);
  border-radius: 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 8rpx;
  transform-origin: left center;
  animation: barGrow 0.8s ease-out 0.4s both;
}

.bar-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
  width: 56rpx;
  text-align: right;
  font-variant-numeric: tabular-nums;
}

/* Tag Cloud */
.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-stat {
  background: var(--accent-light);
  color: var(--accent);
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-xs);
  font-weight: 500;
}

/* Trend */
.trend-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.trend-month {
  width: 140rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.trend-track {
  flex: 1;
  height: 24rpx;
  background: var(--bg-muted);
  border-radius: 8rpx;
  overflow: hidden;
}

.trend-fill {
  height: 100%;
  background: linear-gradient(135deg, #D49058, #B05828);
  border-radius: 8rpx;
  transform-origin: left center;
  animation: barGrow 0.8s ease-out 0.5s both;
}

.trend-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
  width: 80rpx;
  text-align: right;
  font-variant-numeric: tabular-nums;
}

/* Ranking */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 20rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
}

.rank-no {
  width: 44rpx;
  height: 44rpx;
  border-radius: 8rpx;
  background: var(--bg-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-tertiary);
  font-variant-numeric: tabular-nums;
}

.rank-no.top {
  background: var(--accent);
  color: #fff;
}

.rank-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}

.rank-city {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.rank-count {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--accent);
  font-variant-numeric: tabular-nums;
}

.rank-rating {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-variant-numeric: tabular-nums;
}

@keyframes barGrow {
  from { transform: scaleX(0); }
  to { transform: scaleX(1); }
}
