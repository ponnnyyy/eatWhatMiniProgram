.profile-page {
  min-height: 100vh;
  padding: 32rpx 32rpx 140rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.restaurant-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.restaurant-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: var(--bg-surface);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--border);
  transition: background 0.15s;
}

.restaurant-item:active {
  background: var(--bg-muted);
}

.restaurant-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  overflow: hidden;
}

.restaurant-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.restaurant-meta {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.restaurant-arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
  padding-left: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  padding: 40rpx 0;
}
