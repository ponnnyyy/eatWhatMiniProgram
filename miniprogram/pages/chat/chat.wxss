.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
  box-sizing: border-box;
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  flex: 1;
  padding: 0 64rpx;
}

.empty-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D49058, #B05828);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.empty-avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.empty-title {
  font-family: Georgia, 'Noto Serif SC', 'STSong', serif;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.8;
}

.empty-hints {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 40rpx;
  width: 100%;
}

.hint-item {
  background: var(--bg-surface);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  gap: 16rpx;
  transition: all 0.2s;
}

.hint-item:active {
  transform: scale(0.985);
}

.hint-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

/* ===== Chat Messages ===== */
.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}

.messages-inner {
  padding-bottom: 24rpx;
}

/* ===== Message Row ===== */
.message-row {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
  gap: 12rpx;
  animation: msgSlideIn 0.3s ease-out;
}

@keyframes msgSlideIn {
  from {
    opacity: 0;
    transform: translateY(12rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.row-user {
  justify-content: flex-end;
}

.row-ai {
  justify-content: flex-start;
}

/* ===== Avatar ===== */
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.avatar-ai {
  background: linear-gradient(135deg, #D49058, #B05828);
  color: #fff;
}

.avatar-user {
  background: var(--text-primary);
  color: #fff;
}

/* ===== Bubble ===== */
.bubble {
  max-width: 68%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.7;
}

.bubble-user {
  background: var(--text-primary);
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.bubble-ai {
  background: var(--bg-surface);
  color: var(--text-primary);
  border: 1rpx solid var(--border);
  border-bottom-left-radius: 6rpx;
}

.ai-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  max-width: 78%;
}

/* ===== Recommendation Card ===== */
.rec-card {
  background: var(--bg-surface);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 24rpx;
  position: relative;
  overflow: hidden;
  animation: cardReveal 0.35s ease-out;
}

@keyframes cardReveal {
  from {
    opacity: 0;
    transform: translateY(12rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.rec-accent-line {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(135deg, #D49058, #B05828);
}

.rec-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  margin-top: 4rpx;
}

.rec-name {
  font-family: Georgia, 'Noto Serif SC', 'STSong', serif;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.rec-price {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-variant-numeric: tabular-nums;
}

.rec-location {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.rec-city {
  font-size: 22rpx;
  background: var(--accent-light);
  color: var(--accent);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-xs);
  font-weight: 500;
}

.rec-address {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.rec-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 12rpx;
  display: block;
}

.rec-dishes {
  background: var(--bg-muted);
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 12rpx;
}

.rec-dishes-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 6rpx;
}

.rec-dishes-text {
  font-size: 24rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

.rec-reason {
  background: var(--accent-light);
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
  display: flex;
  gap: 10rpx;
  align-items: flex-start;
  margin-top: 4rpx;
}

.rec-reason-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.rec-reason-text {
  font-size: 26rpx;
  color: var(--accent-hover);
  line-height: 1.6;
  font-weight: 500;
}

/* ===== Typing Indicator ===== */
.typing-row {
  animation: msgSlideIn 0.3s ease-out;
}

.typing-bubble {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  min-width: 100rpx;
}

.typing-dots {
  display: flex;
  gap: 10rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--accent);
  animation: dotPulse 1.4s ease-in-out infinite;
}

.typing-dot:nth-child(2) { animation-delay: 0.15s; }
.typing-dot:nth-child(3) { animation-delay: 0.3s; }

@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.25; transform: scale(0.75); }
  40% { opacity: 1; transform: scale(1); }
}

/* ===== Input Area ===== */
.input-area {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--border);
  align-items: center;
  background: var(--bg-surface);
}

.input-wrap {
  flex: 1;
  background: var(--bg-page);
  border: 1rpx solid var(--border);
  border-radius: 24rpx;
  padding: 0 24rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  transition: border-color 0.15s;
}

.input-wrap:focus-within {
  border-color: var(--accent);
}

.chat-input {
  width: 100%;
  height: 76rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 76rpx;
}

.input-placeholder {
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.send-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: var(--bg-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.15s;
}

.send-btn.active {
  background: var(--text-primary);
}

.send-btn.active:active {
  transform: scale(0.93);
}

.send-icon {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-tertiary);
  transition: color 0.15s;
}

.send-btn.active .send-icon {
  color: #fff;
}
