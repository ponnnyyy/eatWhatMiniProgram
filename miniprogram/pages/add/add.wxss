.add-page {
  padding: 24rpx 0 140rpx;
  box-sizing: border-box;
}

/* Page Header */
.page-header {
  margin-bottom: 40rpx;
  padding: 0 40rpx;
}

.page-title {
  font-family: Georgia, 'Noto Serif SC', 'STSong', serif;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  display: block;
  letter-spacing: -0.01em;
}

.page-subtitle {
  font-size: 28rpx;
  color: var(--text-tertiary);
  display: block;
}

/* Form Section */
.form-section {
  background: var(--bg-surface);
  border-radius: var(--radius-md);
  padding: 36rpx;
  border: 1rpx solid var(--border);
  margin: 0 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  background: var(--bg-page);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  min-height: 84rpx;
  line-height: 1.6;
  transition: border-color 0.15s;
}

.form-input:focus {
  border-color: var(--accent);
}

.form-textarea {
  width: 100%;
  background: var(--bg-page);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  min-height: 160rpx;
  box-sizing: border-box;
  line-height: 1.6;
  transition: border-color 0.15s;
}

/* Location Section */
.location-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.location-input {
  flex: 1;
}

.location-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--accent-light);
  color: var(--accent);
  padding: 18rpx 28rpx;
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  width: fit-content;
  white-space: nowrap;
  line-height: 1.4;
  transition: transform 0.15s;
}

.location-btn::after {
  border: none;
}

.location-btn:active {
  transform: scale(0.97);
}

/* Coordinate Display */
.coord-display {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.coord-badge {
  display: inline-block;
  font-size: 24rpx;
  color: var(--accent);
  background: var(--accent-light);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-xs);
  font-family: monospace;
}

/* Map Preview */
.map-preview {
  width: 100%;
  height: 360rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-top: 12rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid var(--border);
}

/* Tags */
.tag-list-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  display: inline-block;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-surface);
  border: 1rpx solid var(--border);
  color: var(--text-secondary);
  transition: all 0.2s;
}

.tag-item:active {
  transform: scale(0.97);
}

.tag-item.selected {
  background: var(--text-primary);
  color: var(--bg-surface);
  border-color: var(--text-primary);
}

/* Image Upload */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-grid-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  position: relative;
}

.image-grid-item image {
  width: 100%;
  height: 100%;
}

.image-grid-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.image-grid-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: var(--bg-muted);
  border: 2rpx dashed var(--border);
}

.image-grid-add .upload-icon {
  font-size: 56rpx;
  color: var(--text-tertiary);
}

.image-grid-add .upload-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* Form Actions */
.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border);
}

.submit-btn {
  flex: 1;
  background: var(--text-primary);
  color: #ffffff;
  border-radius: 100rpx;
  padding: 24rpx;
  font-weight: 500;
  font-size: 30rpx;
  text-align: center;
  border: none;
  line-height: 1.4;
  transition: transform 0.15s;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: scale(0.97);
}

.reset-btn {
  flex: 1;
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--border);
  border-radius: 100rpx;
  padding: 24rpx;
  font-weight: 500;
  font-size: 30rpx;
  text-align: center;
  line-height: 1.4;
  transition: all 0.2s;
}

.reset-btn::after {
  border: none;
}

.reset-btn:active {
  background: var(--bg-surface);
  transform: scale(0.97);
}
